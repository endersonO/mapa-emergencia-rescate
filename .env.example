# Neon Postgres (Vercel Marketplace).
# Si conectas Neon desde Vercel, esta variable se inyecta sola.
# Para desarrollo local: vercel env pull .env.local
DATABASE_URL=

# OpenPanel analytics.
# NEXT_PUBLIC_OPENPANEL_CLIENT_ID comes from the OpenPanel project settings.
# OPENPANEL_API_URL should point to your self-hosted OpenPanel API, including /api.
# Example: https://openpanel.example.com/api
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
OPENPANEL_API_URL=
NEXT_PUBLIC_OPENPANEL_DASHBOARD_URL=
NEXT_PUBLIC_OPENPANEL_PRODUCTION_HOST=terremotovenezuela.app
